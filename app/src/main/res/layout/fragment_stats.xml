<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Statistik"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/blue"
        android:layout_marginBottom="24dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/statsIncome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Income: Rp 0"
            android:textSize="16sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:padding="16dp" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/statsExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Expense: Rp 0"
            android:textSize="16sp"
            android:textColor="#F44336"
            android:textStyle="bold"
            android:padding="16dp" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/statsTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Saldo: Rp 0"
            android:textSize="16sp"
            android:textColor="@color/blue"
            android:textStyle="bold"
            android:padding="16dp" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/statsTopCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pengeluaran terbesar: -"
            android:textSize="16sp"
            android:textColor="#FF9800"
            android:textStyle="bold"
            android:padding="16dp" />
    </androidx.cardview.widget.CardView>

</LinearLayout>
